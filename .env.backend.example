# ============================================
# BACKEND/LAMBDA ENVIRONMENT CONFIGURATION
# ============================================
# Copy this file to .env.backend for local backend testing
# This file is for Lambda functions and backend services ONLY
# For mobile app configuration, see .env.example

# ============================================
# 💻 LOCAL BACKEND TESTING
# ============================================
# Use these when testing Lambda functions locally

# AWS Configuration
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here

# Project Configuration
PROJECT_NAME=madhavai
ENVIRONMENT=development

# DynamoDB Tables (use local or dev tables)
USERS_TABLE=farmer-platform-users-dev
ALERTS_TABLE=farmer-platform-alerts-dev
LESSONS_TABLE=farmer-platform-lessons-dev
PROGRESS_TABLE=farmer-platform-learning-progress-dev
SCHEMES_TABLE=farmer-platform-schemes-dev
MARKET_PRICES_TABLE=farmer-platform-market-prices-dev
SOIL_HEALTH_TABLE=farmer-platform-soil-health-dev

# S3 Buckets
CONTENT_BUCKET=farmer-platform-training-content-dev
SOIL_HEALTH_IMAGES_BUCKET=farmer-platform-soil-health-images-dev

# SNS Topic (get this after running Terraform)
# Run: cd infrastructure/terraform && terraform output sns_topic_arn
SNS_TOPIC_ARN=arn:aws:sns:ap-south-1:xxxxxxxxxxxx:madhavai-alerts-dev

# Disaster Recovery
PRIMARY_REGION=ap-south-1
BACKUP_REGION=ap-southeast-1

# ============================================
# 🚀 PRODUCTION DEPLOYMENT (GitHub Secrets)
# ============================================
# Add these secrets to GitHub repository settings:
# Settings → Secrets and variables → Actions → New repository secret

# Required secrets for backend deployment:
# - AWS_ACCESS_KEY_ID (AWS credentials for Terraform)
# - AWS_SECRET_ACCESS_KEY (AWS credentials for Terraform)
# - ALERT_EMAIL (email for CloudWatch alerts)

# Optional:
# - SNYK_TOKEN (for security scanning)
# - SLACK_WEBHOOK (for deployment notifications)


# ============================================
# ✅ TERRAFORM CREATES AUTOMATICALLY
# ============================================
# These are created by Terraform and injected into Lambda functions.
# You DON'T need to add them to GitHub Secrets:
#
# ✅ SNS_TOPIC_ARN - Created by infrastructure/terraform/sns.tf
# ✅ USERS_TABLE - Created by infrastructure/terraform/dynamodb.tf
# ✅ ALERTS_TABLE - Created by infrastructure/terraform/dynamodb.tf
# ✅ LESSONS_TABLE - Created by infrastructure/terraform/dynamodb.tf
# ✅ PROGRESS_TABLE - Created by infrastructure/terraform/dynamodb.tf
# ✅ SCHEMES_TABLE - Created by infrastructure/terraform/dynamodb.tf
# ✅ MARKET_PRICES_TABLE - Created by infrastructure/terraform/dynamodb.tf
# ✅ SOIL_HEALTH_TABLE - Created by infrastructure/terraform/dynamodb.tf
# ✅ CONTENT_BUCKET - Created by infrastructure/terraform/s3.tf
# ✅ SOIL_HEALTH_IMAGES_BUCKET - Created by infrastructure/terraform/s3.tf
#
# Terraform automatically injects these into Lambda environment variables
# via infrastructure/terraform/lambda.tf

# ============================================
# 📋 HOW TO GET SNS_TOPIC_ARN (for local testing)
# ============================================
# After running Terraform:
# $ cd infrastructure/terraform
# $ terraform output sns_topic_arn
# Copy the output and paste it above

# ============================================
# 🔄 DEPLOYMENT FLOW
# ============================================
# 1. Push code to GitHub (main or develop branch)
# 2. GitHub Actions runs backend-ci-cd.yml workflow
# 3. Terraform creates all AWS resources (SNS, DynamoDB, S3, Lambda)
# 4. Terraform automatically injects environment variables into Lambda
# 5. Lambda functions run with all variables already set
#
# You only need to set AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY
# in GitHub Secrets. Everything else is automatic!
