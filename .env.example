# ============================================
# MOBILE APP ENVIRONMENT CONFIGURATION
# ============================================
# Copy this file to .env and fill in your values
# This file is for the React Native mobile app ONLY
# For backend/Lambda configuration, see .env.backend.example

# ============================================
# 📱 LOCAL DEVELOPMENT SETUP
# ============================================

# API Configuration
API_BASE_URL=http://localhost:3000/api
API_TIMEOUT=30000
ENABLE_API=false
ENABLE_LOGGING=true
STORAGE_LIMIT_MB=500
SYNC_INTERVAL_MS=60000
MAX_RETRY_ATTEMPTS=3

# OTA Update Service
OTA_API_BASE_URL=https://api.madhavai.app

# Android Build (for local release builds)
ANDROID_KEYSTORE_PASSWORD=your_keystore_password
ANDROID_KEY_ALIAS=your_key_alias
ANDROID_KEY_PASSWORD=your_key_password

# ============================================
# 🚀 PRODUCTION DEPLOYMENT (GitHub Secrets)
# ============================================
# Add these secrets to GitHub repository settings:
# Settings → Secrets and variables → Actions → New repository secret

# For production builds, add these to GitHub Secrets:
# - API_BASE_URL (production API endpoint)
# - ANDROID_KEYSTORE_BASE64 (base64 encoded keystore file)
# - ANDROID_KEYSTORE_PASSWORD
# - ANDROID_KEY_ALIAS
# - ANDROID_KEY_PASSWORD
# - GOOGLE_PLAY_SERVICE_ACCOUNT_JSON (optional, for Play Store upload)